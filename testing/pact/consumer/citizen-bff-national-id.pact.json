{
  "consumer": { "name": "citizen-bff" },
  "provider": { "name": "national-id-service" },
  "interactions": [
    {
      "description": "fetch citizen profile by token",
      "request": {
        "method": "GET",
        "path": "/v1/citizens/by-token/{token}",
        "headers": { "Accept": "application/json", "X-Consent-Token": "valid-token" }
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": { "token": "abc123", "full_name": "Asha P", "dob": "1990-04-12" }
      }
    }
  ],
  "metadata": { "pactSpecification": { "version": "3.0.0" } }
}

{
  "expectation_suite_name": "civic_grievances",
  "expectations": [
    { "expectation_type": "expect_column_values_to_not_be_null",       "kwargs": { "column": "grievance_id" } },
    { "expectation_type": "expect_column_values_to_be_unique",          "kwargs": { "column": "grievance_id" } },
    { "expectation_type": "expect_column_values_to_match_regex",        "kwargs": { "column": "grievance_id", "regex": "^[A-Z0-9-]{8,}$" } },
    { "expectation_type": "expect_column_values_to_be_in_set",          "kwargs": { "column": "status", "value_set": ["open","in_progress","escalated","resolved","closed"] } },
    { "expectation_type": "expect_table_row_count_to_be_between",       "kwargs": { "min_value": 100, "max_value": 5000000 } }
  ],
  "meta": { "great_expectations_version": "1.0.0" }
}
